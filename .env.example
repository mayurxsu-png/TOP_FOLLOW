# ═══════════════════════════════════════════════════════════
#  TOP_PROJECT Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/topfollow?retryWrites=true&w=majority
MONGO_DB_NAME=topfollow

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
SECRET_KEY=change_this_to_a_random_string
